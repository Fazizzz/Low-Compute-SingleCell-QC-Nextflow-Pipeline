manifest {
    name        = 'scq'
    description = 'Single Cell Quick QC pipeline'
    version     = '0.1.0'
    nextflowVersion = '>=24.10.0'
    mainScript  = 'main.nf'
}

params {
    samplesheet           = null
    genome_fasta          = null
    genome_gtf            = null
    prebuilt_index        = null
    t2g                   = null
    // nac workflow files (only required when --workflow full + --prebuilt_index)
    cdna_t2c              = null
    nascent_t2c           = null
    outdir                = 'results'
    workflow              = 'quick'    // 'quick' (cDNA only) or 'full' (nac: spliced + nascent)
    min_umi_threshold     = 200
    threads               = 4
    ref_cache_dir         = "${System.getenv('HOME')}/.scq_cache"
    run_celltypist        = false
    celltypist_model_path = null
    // Compute-profile-tuned defaults (overridden by -profile local|hpc|aws):
    kb_threads_full       = 2     // kallisto bus threads in --workflow full
    kb_threads_quick      = null  // null -> use task.cpus from the active profile
    bustools_mem_cap_gb   = 12    // ceiling for bustools sort -m
}

includeConfig 'conf/base.config'

profiles {
    // Compute envelope (pick one):
    local {
        includeConfig 'conf/local.config'
    }
    hpc {
        includeConfig 'conf/hpc.config'
    }
    aws {
        includeConfig 'conf/aws.config'
    }
    // Container engine (pick one, combine with a compute profile via comma):
    docker {
        includeConfig 'conf/docker.config'
    }
    singularity {
        includeConfig 'conf/singularity.config'
    }
    // Convenience:
    stub {
        // for -stub-run convenience
    }
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,peak_rss,peak_vmem,cpus,memory'
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}
