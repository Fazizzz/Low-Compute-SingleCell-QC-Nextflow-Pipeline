// Local profile: laptop/desktop with <= 16 GB RAM and 4-8 cores.
// Inherits process_low/medium/high defaults from base.config (already <= 14 GB).
// Caps the Nextflow local executor so it never schedules beyond the host envelope.
//
// Use this for quick (cDNA-only) mode. Full (nac) mode does NOT fit the human
// index here — switch to -profile hpc or build a protein-coding-only nac index
// (scripts/shell/build_pc_nac_index.sh).

executor {
    name   = 'local'
    cpus   = 4
    memory = '14 GB'
}

params {
    // kb count threads (overrides the hard-coded fallback in kb_count.nf)
    kb_threads_full     = 2
    kb_threads_quick    = 4
    // bustools sort -m ceiling, in GB
    bustools_mem_cap_gb = 10
}
