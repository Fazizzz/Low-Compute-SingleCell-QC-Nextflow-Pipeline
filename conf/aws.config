// AWS profile: validated on m6i.4xlarge (16 vCPU / 64 GB RAM, 300 GB gp3 EBS).
// Identical to the resource envelope hpc.config grants, with two tweaks:
//   - process_high memory = 48 GB (forces ONE kb count at a time on a 64 GB
//     host so concurrent KB_COUNTs can't OOM each other; the nac index is
//     6.7 GB resident + several GB working memory per process).
//   - kb count threads default to 2 for full mode (matches the validated run).
//     Raise via --kb_threads_full=N if you swap in a beefier instance type.

process {
    withLabel: process_medium {
        cpus   = 4
        memory = '12 GB'
    }
    withLabel: process_high {
        cpus   = 8
        memory = '48 GB'
        time   = '6h'
    }
}

params {
    kb_threads_full     = 2
    kb_threads_quick    = 8
    bustools_mem_cap_gb = 32
}
