// HPC profile: SLURM/PBS/local node with abundant RAM and 16+ cores.
// Lifts the laptop caps so the scheduler grants full requested resources.
// Use this with --workflow full on the standard ~7 GB human nac index.

// Sized so the profile fits a 64 GB HPC node (the smallest typical allocation)
// while still leaving Nextflow + OS roughly 8 GB of headroom. Bigger nodes
// just use the same envelope; override with --memory_high=N.GB if you have
// real high-mem allocations to spend.
process {
    withLabel: process_medium {
        cpus   = 8
        memory = '20 GB'
    }
    withLabel: process_high {
        cpus   = 16
        memory = '56 GB'
        time   = '6h'
    }
}

params {
    kb_threads_full     = 8
    kb_threads_quick    = 16
    bustools_mem_cap_gb = 48
}
