// Default process resources. Tuned for a typical laptop / small workstation:
// 4 cores, 16 GB RAM available. Override with a compute profile
// (-profile local | hpc | aws) to scale up.
process {
    errorStrategy = 'terminate'
    maxRetries    = 1

    withLabel: process_low {
        cpus   = 1
        memory = '2 GB'
        time   = '30m'
    }
    withLabel: process_medium {
        cpus   = 2
        memory = '6 GB'
        time   = '2h'
    }
    withLabel: process_high {
        // KB_COUNT lives here. In quick (cDNA-only) mode the index is ~1 GB,
        // so this fits comfortably in 14 GB. In full (nac) mode the human
        // index is ~7 GB; on a 16 GB laptop, kb count needs at least the
        // nac profile (see conf/hpc.config) to avoid OOM. Pick a compute
        // profile that matches your host.
        cpus   = 4
        memory = '14 GB'
        time   = '4h'
    }

    // FASTP can intermittently stall on a single gzipped fastq stream
    // (gunzip pathology, EBS throttle, etc.). Cap the wall time so the
    // pipeline doesn't deadlock if one sample hangs, and let it skip that
    // sample on a second failure. KB_COUNT does not depend on FASTP output,
    // so other samples and downstream analysis proceed unaffected.
    withName: 'FASTP' {
        time          = '20.min'
        errorStrategy = { task.attempt < 2 ? 'retry' : 'ignore' }
        maxRetries    = 1
    }
}
